# ============================================================
#  I2-Lab-Copilot 環境変数テンプレート
#  使い方: cp .env.example .env して値を埋める（.env は gitignore 済み）
#  本番(Cloud Run)では値は Secret Manager から注入し、.env は使わない
# ============================================================

# --- GCP ---
GOOGLE_CLOUD_PROJECT=nakazawa-laborary
GOOGLE_CLOUD_LOCATION=asia-northeast1
# ADK/Vertex AI をサービスアカウント経由で使う（APIキー不要）
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# --- GCS ---
GCS_BUCKET_RECORDINGS=i2-lab-copilot-recordings

# --- Storage backend ---
# memory    : 権限不要・インメモリ（ローカル開発の既定）
# firestore : 本番。FIRESTORE_EMULATOR_HOST を設定するとローカルエミュレータに接続
STORAGE_BACKEND=memory
# 例: Firestore エミュレータ利用時（make firestore-emulator）
# STORAGE_BACKEND=firestore
# FIRESTORE_EMULATOR_HOST=localhost:8080

# --- Vertex AI / Gemini ---
GEMINI_MODEL=gemini-2.5-pro
GEMINI_MODEL_FAST=gemini-2.5-flash

# --- Discord（値は Secret Manager: discord-bot-token を参照。ローカル開発のみ直書き可）---
# 実IDは公開リポジトリに入れない。ローカル .env にのみ記載する
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CONSENT_CHANNEL_ID=
# 要約の投稿先 / 個人FBはDMで送るので不要
DISCORD_SUMMARY_CHANNEL_ID=

# --- GitHub（報告書ソース: nakalab/progress2026, ブランチ別）---
GITHUB_REPORTS_OWNER=nakalab
GITHUB_REPORTS_REPO=progress2026
# Secret Manager: github-readonly-token を参照
GITHUB_TOKEN=

# --- Pub/Sub ---
PUBSUB_TOPIC_RECORDING_DONE=recording-done

# --- Logging ---
LOG_LEVEL=INFO
