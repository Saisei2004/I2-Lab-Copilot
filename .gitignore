# --- Env / secrets ---
.env
.env.*
!.env.example
*.key
*.pem
service-account*.json
gha-creds-*.json

# --- Tooling caches ---
.ruff_cache/
.pytest_cache/
.mypy_cache/
.pyright/
.coverage
htmlcov/

# --- Terraform ---
